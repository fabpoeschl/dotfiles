{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "permission": {
    "external_directory": "deny",
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      ".envrc": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.envrc": "deny",
      "**/.ssh/**": "deny",
      "**/.aws/credentials": "deny",
      "**/.aws/config": "deny",
      "**/.gnupg/**": "deny",
      "**/*.pem": "deny",
      "**/id_rsa*": "deny",
      "**/id_ed25519*": "deny",
      "**/id_ecdsa*": "deny",
      "**/id_dsa*": "deny",
      "**/.netrc": "deny",
      "**/.npmrc": "deny",
      "**/.pypirc": "deny"
    },
    "edit": "ask",
    "write": "ask",
    "bash": {
      "*": "ask",
      "sudo": "deny",
      "sudo *": "deny",
      "doas": "deny",
      "doas *": "deny",
      "su": "deny",
      "su *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      "rm -rf $HOME": "deny",
      "rm -rf $HOME/*": "deny",
      ":(){ :|:&};:": "deny",
      "chmod -R 777*": "deny",
      "chown -R *": "deny",
      "git push --force*": "ask",
      "git push -f*": "ask",
      "git reset --hard*": "ask",
      "git clean -fd*": "ask",
      "git clean -fdx*": "ask",
      "git branch -D*": "ask",
      "git checkout -- *": "ask"
    },
    "webfetch": "ask"
  },
  "agent": {
    "build": {
      "permission": {
        "edit": "allow",
        "write": "allow",
        "bash": {
          "*": "allow",
          "sudo": "deny",
          "sudo *": "deny",
          "doas": "deny",
          "doas *": "deny",
          "su": "deny",
          "su *": "deny",
          "rm -rf /": "deny",
          "rm -rf /*": "deny",
          "rm -rf ~": "deny",
          "rm -rf ~/*": "deny",
          "rm -rf $HOME": "deny",
          "rm -rf $HOME/*": "deny",
          ":(){ :|:&};:": "deny",
          "chmod -R 777*": "deny",
          "chown -R *": "deny",
          "git push --force*": "ask",
          "git push -f*": "ask",
          "git reset --hard*": "ask",
          "git clean -fd*": "ask",
          "git clean -fdx*": "ask",
          "git branch -D*": "ask",
          "git checkout -- *": "ask"
        },
        "webfetch": "allow"
      }
    },
    "plan": {
      "tools": {
        "write": true,
        "edit": true,
        "patch": true
      },
      "permission": {
        "edit": {
          "*": "deny",
          "agents/doc/tasks/**": "allow",
          "agents/doc/plans/**": "allow",
          "agents/doc/adr/**": "allow"
        },
        "write": {
          "*": "deny",
          "agents/doc/tasks/**": "allow",
          "agents/doc/plans/**": "allow",
          "agents/doc/adr/**": "allow"
        },
        "patch": {
          "*": "deny",
          "agents/doc/tasks/**": "allow",
          "agents/doc/plans/**": "allow",
          "agents/doc/adr/**": "allow"
        }
      }
    },
    "review": {
      "mode": "primary",
      "description": "Code review with read-only project access. May write to agents/doc/tasks and agents/doc/reviews for review notes and task tracking.",
      "tools": {
        "write": true,
        "edit": true,
        "patch": true
      },
      "permission": {
        "edit": {
          "*": "deny",
          "agents/doc/tasks/**": "allow",
          "agents/doc/reviews/**": "allow"
        },
        "write": {
          "*": "deny",
          "agents/doc/tasks/**": "allow",
          "agents/doc/reviews/**": "allow"
        },
        "patch": {
          "*": "deny",
          "agents/doc/tasks/**": "allow",
          "agents/doc/reviews/**": "allow"
        }
      }
    }
  }
}
