#!/usr/bin/env bash
# Port-forward a database pod from a Kubernetes cluster.
#
# Usage:
#   remote-db-connect -c <context> -n <namespace> -d <database-name>
#
# Finds the first pod whose name contains <database-name> in the given
# namespace/context and forwards its database port to localhost.
# Supports PostgreSQL (5432), MySQL (3306), Redis (6379), and MongoDB (27017).

set -euo pipefail

usage() {
  echo "Usage: remote-db-connect -c <context> -n <namespace> -d <database>"
  echo ""
  echo "Options:"
  echo "  -c, --context     Kubernetes context (e.g. staging, production)"
  echo "  -n, --namespace   Kubernetes namespace"
  echo "  -d, --database    Substring to match against pod names (e.g. postgres, redis)"
  echo ""
  echo "Examples:"
  echo "  remote-db-connect -c staging -n my-ns -d my-postgres"
  echo "  remote-db-connect --context production --namespace payments --database redis"
  exit 1
}

CONTEXT=""
NAMESPACE=""
DB_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -c|--context)   CONTEXT="$2";   shift 2 ;;
    -n|--namespace) NAMESPACE="$2"; shift 2 ;;
    -d|--database)  DB_NAME="$2";   shift 2 ;;
    -h|--help)      usage ;;
    *)              echo "Error: unknown option '$1'"; usage ;;
  esac
done

[[ -z "$CONTEXT" || -z "$NAMESPACE" || -z "$DB_NAME" ]] && usage

# Find the pod
POD=$(kubectl --context "$CONTEXT" -n "$NAMESPACE" get pods \
  -o jsonpath='{.items[*].metadata.name}' | tr ' ' '\n' | grep "$DB_NAME" | head -1)

if [[ -z "$POD" ]]; then
  echo "Error: no pod matching '$DB_NAME' found in $NAMESPACE (context: $CONTEXT)"
  exit 1
fi

echo "Found pod: $POD"

# Detect database type and pick the right port
detect_port() {
  local name="${DB_NAME,,}"
  case "$name" in
    *postgres*|*pg*|*pgsql*)  echo 5432 ;;
    *mysql*|*maria*)          echo 3306 ;;
    *redis*)                  echo 6379 ;;
    *mongo*)                  echo 27017 ;;
    *)
      # Fall back to inspecting the container ports
      local port
      port=$(kubectl --context "$CONTEXT" -n "$NAMESPACE" get pod "$POD" \
        -o jsonpath='{.spec.containers[0].ports[0].containerPort}' 2>/dev/null)
      if [[ -n "$port" ]]; then
        echo "$port"
      else
        echo ""
      fi
      ;;
  esac
}

REMOTE_PORT=$(detect_port)

if [[ -z "$REMOTE_PORT" ]]; then
  echo "Error: could not detect database port. Specify it manually:"
  echo "  kubectl --context $CONTEXT -n $NAMESPACE port-forward $POD <local>:<remote>"
  exit 1
fi

LOCAL_PORT="$REMOTE_PORT"

echo "Port-forwarding localhost:$LOCAL_PORT → $POD:$REMOTE_PORT"
echo "Press Ctrl-C to stop"
echo ""
exec kubectl --context "$CONTEXT" -n "$NAMESPACE" port-forward "$POD" "$LOCAL_PORT:$REMOTE_PORT"
