#!/usr/bin/env bash
# Connect to an application pod in a Kubernetes cluster.
#
# Usage:
#   remote-pod-connect -c <context> -n <namespace> -a <app-name> [action] [args...]
#
# Actions:
#   shell   (default) Open an interactive shell in the pod
#   forward <local-port>:<remote-port>  Port-forward to the pod
#   logs    Tail the pod logs
#
# Examples:
#   remote-pod-connect -c staging -n my-ns -a my-api
#   remote-pod-connect -c staging -n my-ns -a my-api forward 3000:3000
#   remote-pod-connect -c staging -n my-ns -a my-api logs

set -euo pipefail

if ! command -v kubectl &>/dev/null; then
  echo "Error: kubectl is not installed or not in PATH"
  exit 1
fi

usage() {
  echo "Usage: remote-pod-connect -c <context> -n <namespace> -a <app> [action] [args...]"
  echo ""
  echo "Options:"
  echo "  -c, --context       Kubernetes context (e.g. staging, production)"
  echo "  -n, --namespace     Kubernetes namespace"
  echo "  -a, --application   Substring to match against pod names"
  echo ""
  echo "Actions:"
  echo "  shell                          Open a shell (default)"
  echo "  forward <local:remote> [...]   Port-forward (multiple mappings allowed)"
  echo "  logs                           Tail pod logs"
  echo ""
  echo "Examples:"
  echo "  remote-pod-connect -c staging -n my-ns -a my-api"
  echo "  remote-pod-connect -c staging -n my-ns -a my-api forward 3000:3000"
  echo "  remote-pod-connect -c staging -n my-ns -a my-api forward 3000:3000 5678:5678"
  echo "  remote-pod-connect -c staging -n my-ns -a my-api logs"
  exit 1
}

CONTEXT=""
NAMESPACE=""
APP_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -c|--context)     [[ $# -lt 2 ]] && { echo "Error: $1 requires a value"; usage; }; CONTEXT="$2";   shift 2 ;;
    -n|--namespace)   [[ $# -lt 2 ]] && { echo "Error: $1 requires a value"; usage; }; NAMESPACE="$2"; shift 2 ;;
    -a|--application) [[ $# -lt 2 ]] && { echo "Error: $1 requires a value"; usage; }; APP_NAME="$2";  shift 2 ;;
    -h|--help)        usage ;;
    -*)               echo "Error: unknown option '$1'"; usage ;;
    *)                break ;;  # remaining args are action + action args
  esac
done

[[ -z "$CONTEXT" || -z "$NAMESPACE" || -z "$APP_NAME" ]] && usage

ACTION="${1:-shell}"
[[ $# -gt 0 ]] && shift  # consume action arg

# Find a running pod
POD=$(kubectl --context "$CONTEXT" -n "$NAMESPACE" get pods \
  --field-selector=status.phase=Running \
  -o jsonpath='{.items[*].metadata.name}' | tr ' ' '\n' | grep -F "$APP_NAME" | head -1)

if [[ -z "$POD" ]]; then
  echo "Error: no running pod matching '$APP_NAME' found in $NAMESPACE (context: $CONTEXT)"
  exit 1
fi

echo "Found pod: $POD"

case "$ACTION" in
  shell)
    # Try bash first, fall back to sh
    echo "Opening shell..."
    kubectl --context "$CONTEXT" -n "$NAMESPACE" exec -it "$POD" -- bash 2>/dev/null \
      || kubectl --context "$CONTEXT" -n "$NAMESPACE" exec -it "$POD" -- sh
    ;;

  forward)
    if [[ $# -lt 1 ]]; then
      echo "Error: forward requires at least one port mapping (e.g. 3000:3000)"
      exit 1
    fi
    echo "Port-forwarding: $*"
    echo "Press Ctrl-C to stop"
    echo ""
    exec kubectl --context "$CONTEXT" -n "$NAMESPACE" port-forward "$POD" "$@"
    ;;

  logs)
    exec kubectl --context "$CONTEXT" -n "$NAMESPACE" logs -f "$POD"
    ;;

  *)
    echo "Error: unknown action '$ACTION'"
    usage
    ;;
esac
