FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV HOME=/root

# Minimal base (what a real system would have)
RUN apt-get update && apt-get install -y \
    git sudo curl wget ca-certificates software-properties-common \
    && rm -rf /var/lib/apt/lists/*

# Install chezmoi
RUN BINDIR=/usr/local/bin sh -c "$(curl -fsLS get.chezmoi.io)" && chezmoi --version

# Copy dotfiles as chezmoi source
COPY . /root/.local/share/chezmoi
WORKDIR /root

CMD ["bash"]
